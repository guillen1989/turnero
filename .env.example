FLASK_ENV=development
SECRET_KEY=cambia-esto-por-un-valor-secreto-real
DATABASE_URL=postgresql://usuario:contraseña@localhost:5432/cambiaturnos

# VAPID keys para Web Push (generar con: python -c "from pywebpush import Vapid; v=Vapid(); v.generate_keys(); print(v.private_key, v.public_key)")
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_CLAIM_EMAIL=tu@email.com

# URL de producción (para smoke tests post-deploy)
APP_URL=https://tu-app.railway.app

# Resend (email transaccional vía HTTPS API, no SMTP: Railway bloquea SMTP
# saliente en el plan Hobby). Crear cuenta gratis en resend.com, verificar
# turnero.xyz en resend.com/domains y generar una API key.
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@turnero.xyz
