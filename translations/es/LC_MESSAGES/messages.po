msgid "5. Consulta lo que publican tus compañeros"
msgstr ""

#: app/templates/main/como_funciona.html:136
msgid "En \"Buscar cambios\" ves todas las publicaciones abiertas de tu unidad."
msgstr ""

#: app/templates/main/como_funciona.html:137
